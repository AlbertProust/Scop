# Simple 3D Bag Model
# Generated OBJ file for a basic bag shape
mtllib bag.mtl
o Bag

# Main body vertices - front face
v -1.0 0.0 1.0
v 1.0 0.0 1.0
v 1.0 2.0 1.0
v -1.0 2.0 1.0

# Main body vertices - back face
v -1.0 0.0 -1.0
v 1.0 0.0 -1.0
v 1.0 2.0 -1.0
v -1.0 2.0 -1.0

# Bottom corners - front
v -0.8 0.0 0.8
v 0.8 0.0 0.8

# Bottom corners - back
v -0.8 0.0 -0.8
v 0.8 0.0 -0.8

# Left handle vertices
v -1.1 2.0 0.0
v -1.3 3.0 0.0
v -1.2 3.5 0.0
v -1.1 4.0 0.0

# Right handle vertices
v 1.1 2.0 0.0
v 1.3 3.0 0.0
v 1.2 3.5 0.0
v 1.1 4.0 0.0

# Bag opening rim
v -0.8 2.0 0.8
v 0.8 2.0 0.8
v 0.8 2.0 -0.8
v -0.8 2.0 -0.8

usemtl Material

# Front face
f 1 2 3 4

# Back face
f 6 5 8 7

# Bottom face
f 1 9 10 2
f 5 12 11 6

# Left face
f 1 4 8 5

# Right face
f 2 6 7 3

# Top rim faces
f 4 3 22 21
f 8 7 23 24
f 4 21 24 8
f 3 7 23 22

# Left handle
f 4 13 14 21
f 13 14 15 16
f 16 15 21 24

# Right handle
f 3 17 18 22
f 17 18 19 20
f 20 19 22 23

# Inside bottom
f 9 1 5 11
f 2 10 22 3
f 1 4 21 9
